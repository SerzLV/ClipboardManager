<mah:MetroWindow x:Class="ClipboardManager.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:helper="clr-namespace:ClipboardManager.Helper"
                 xmlns:views="clr-namespace:ClipboardManager.Views"
                 mc:Ignorable="d"
                 Title="{Binding L.WindowTitle}"
                 Width="1250"
                 Height="760"
                 MinWidth="760"
                 MinHeight="560"
                 TitleBarHeight="44"
                 TitleCharacterCasing="Normal"
                 TitleForeground="#F8FAFC"
                 WindowTitleBrush="#111827"
                 NonActiveWindowTitleBrush="#1F2937"
                 GlowBrush="#2563EB"
                 BorderBrush="#111827"
                 BorderThickness="1"
                 Icon="Resources/Images/app.ico"
                 ShowIconOnTitleBar="True"
                 WindowStartupLocation="CenterScreen"
                 Background="#F6F7F9"
                 FontFamily="Segoe UI"
                 Loaded="MetroWindow_Loaded"
                 Closing="MetroWindow_Closing"
                 TextOptions.TextFormattingMode="Display"
                 UseLayoutRounding="True">
    <mah:MetroWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/MainWindowResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </mah:MetroWindow.Resources>

    <mah:MetroWindow.RightWindowCommands>
        <mah:WindowCommands>
            <Button Command="{Binding ToggleSettingsCommand}"
                    Style="{StaticResource TitleBarIconButtonStyle}"
                    ToolTip="{Binding L.SettingsToolTip}">
                <Viewbox Width="18" Height="18">
                    <iconPacks:Lucide Kind="Settings" Width="18" Height="18" />
                </Viewbox>
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.RightWindowCommands>

    <mah:MetroWindow.Flyouts>
        <mah:FlyoutsControl>
            <mah:Flyout Header="{Binding L.SettingsTitle}"
                        Position="Right"
                        Width="380"
                        Theme="Light"
                        IsPinned="False"
                        CloseButtonVisibility="Visible"
                        IsOpen="{Binding IsSettingsOpen, Mode=TwoWay}">
                <views:SettingsFlyoutContent />
            </mah:Flyout>
        </mah:FlyoutsControl>
    </mah:MetroWindow.Flyouts>

    <mah:MetroWindow.Content>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <views:AppHeaderView Grid.Row="0" />

            <Border Grid.Row="1"
                    Margin="0,18,0,0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource StrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14,10">
                <Grid MinHeight="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Viewbox Width="17"
                             Height="17"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             Opacity="0.65">
                        <iconPacks:Material Kind="Magnify" Width="17" Height="17" />
                    </Viewbox>

                    <Grid Grid.Column="1"
                          VerticalAlignment="Center">
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{StaticResource TextBrush}"
                                 FontSize="14"
                                 Padding="0"
                                 VerticalContentAlignment="Center" />
                        <TextBlock Text="{Binding L.SearchPlaceholder}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="14"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsSearchPlaceholderVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>

                    <TextBlock Grid.Column="2"
                               Text="{Binding SearchResultText}"
                               Margin="14,0,8,0"
                               VerticalAlignment="Center"
                               Style="{StaticResource MutedTextStyle}"
                               Visibility="{Binding IsSearchActive, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <Button Grid.Column="3"
                            Command="{Binding ClearSearchCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="{Binding L.ClearSearchToolTip}"
                            Visibility="{Binding IsSearchActive, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Viewbox Width="16" Height="16">
                            <iconPacks:Material Kind="Close" Width="16" Height="16" />
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <WrapPanel Grid.Row="2"
                       Margin="0,14,0,10"
                       ClipToBounds="False">
                <RadioButton Style="{StaticResource SectionTabButtonStyle}"
                             MinWidth="192"
                             IsChecked="{Binding IsFavoritesSectionSelected, Mode=OneWay}"
                             Command="{Binding SelectSectionCommand}"
                             CommandParameter="0">
                    <Grid ClipToBounds="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SectionTabIconStyle}"
                                Background="{StaticResource AmberSoftBrush}">
                            <Grid>
                                <Viewbox Width="15"
                                         Height="15"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <iconPacks:Material Kind="Star" Width="15" Height="15" />
                                </Viewbox>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding L.FavoritesTab}"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Style="{StaticResource TabBadgeStyle}"
                                Background="{StaticResource AmberSoftBrush}">
                            <TextBlock Text="{Binding FavoriteCount, FallbackValue=0}"
                                       Foreground="{StaticResource AmberBrush}"
                                       Style="{StaticResource TabBadgeTextStyle}" />
                        </Border>
                    </Grid>
                </RadioButton>

                <RadioButton Style="{StaticResource SectionTabButtonStyle}"
                             MinWidth="184"
                             IsChecked="{Binding IsSecretsSectionSelected, Mode=OneWay}"
                             Command="{Binding SelectSectionCommand}"
                             CommandParameter="1">
                    <Grid ClipToBounds="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SectionTabIconStyle}"
                                Background="{StaticResource SecretSoftBrush}">
                            <Grid>
                                <Viewbox Width="15"
                                         Height="15"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <iconPacks:Material Kind="Lock" Width="15" Height="15" />
                                </Viewbox>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding L.SecretsTab}"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Style="{StaticResource TabBadgeStyle}"
                                Background="{StaticResource SecretSoftBrush}">
                            <TextBlock Text="{Binding SecretCount, FallbackValue=0}"
                                       Foreground="{StaticResource SecretBrush}"
                                       Style="{StaticResource TabBadgeTextStyle}" />
                        </Border>
                    </Grid>
                </RadioButton>

                <RadioButton Style="{StaticResource SectionTabButtonStyle}"
                             IsChecked="{Binding IsFilesSectionSelected, Mode=OneWay}"
                             Command="{Binding SelectSectionCommand}"
                             CommandParameter="2">
                    <Grid ClipToBounds="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SectionTabIconStyle}"
                                Background="{StaticResource PrimarySoftBrush}">
                            <Grid>
                                <Viewbox Width="15"
                                         Height="15"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <iconPacks:FontAwesome Kind="FileSolid" Width="15" Height="15" />
                                </Viewbox>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding L.FilesTab}"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Style="{StaticResource TabBadgeStyle}"
                                Background="{StaticResource PrimarySoftBrush}">
                            <TextBlock Text="{Binding FileCount, FallbackValue=1}"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Style="{StaticResource TabBadgeTextStyle}" />
                        </Border>
                    </Grid>
                </RadioButton>

                <RadioButton Style="{StaticResource SectionTabButtonStyle}"
                             IsChecked="{Binding IsTextsSectionSelected, Mode=OneWay}"
                             Command="{Binding SelectSectionCommand}"
                             CommandParameter="3">
                    <Grid ClipToBounds="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SectionTabIconStyle}"
                                Background="{StaticResource AmberSoftBrush}">
                            <Grid>
                                <Viewbox Width="15"
                                         Height="15"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <iconPacks:Material Kind="ContentCopy" Width="15" Height="15" />
                                </Viewbox>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding L.TextTab}"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Style="{StaticResource TabBadgeStyle}"
                                Background="{StaticResource AmberSoftBrush}">
                            <TextBlock Text="{Binding TextCount, FallbackValue=3}"
                                       Foreground="{StaticResource AmberBrush}"
                                       Style="{StaticResource TabBadgeTextStyle}" />
                        </Border>
                    </Grid>
                </RadioButton>

                <RadioButton Style="{StaticResource SectionTabButtonStyle}"
                             MinWidth="176"
                             IsChecked="{Binding IsUrlsSectionSelected, Mode=OneWay}"
                             Command="{Binding SelectSectionCommand}"
                             CommandParameter="4">
                    <Grid ClipToBounds="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SectionTabIconStyle}"
                                Background="{StaticResource TealSoftBrush}">
                            <Grid>
                                <Viewbox Width="15"
                                         Height="15"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <iconPacks:FontAwesome Kind="InternetExplorerBrands" Width="15" Height="15" />
                                </Viewbox>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding L.LinksTab}"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Style="{StaticResource TabBadgeStyle}"
                                Background="{StaticResource TealSoftBrush}">
                            <TextBlock Text="{Binding UrlCount, FallbackValue=2}"
                                       Foreground="{StaticResource TealBrush}"
                                       Style="{StaticResource TabBadgeTextStyle}" />
                        </Border>
                    </Grid>
                </RadioButton>

                <RadioButton Style="{StaticResource SectionTabButtonStyle}"
                             MinWidth="224"
                             IsChecked="{Binding IsImagesSectionSelected, Mode=OneWay}"
                             Command="{Binding SelectSectionCommand}"
                             CommandParameter="5">
                    <Grid ClipToBounds="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SectionTabIconStyle}"
                                Background="{StaticResource RoseSoftBrush}">
                            <Grid>
                                <Viewbox Width="15"
                                         Height="15"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <iconPacks:Material Kind="ContentCopy" Width="15" Height="15" />
                                </Viewbox>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding L.ImagesTab}"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Style="{StaticResource TabBadgeStyle}"
                                Background="{StaticResource RoseSoftBrush}">
                            <TextBlock Text="{Binding ImageCount, FallbackValue=2}"
                                       Foreground="{StaticResource RoseBrush}"
                                       Style="{StaticResource TabBadgeTextStyle}" />
                        </Border>
                    </Grid>
                </RadioButton>
            </WrapPanel>

            <TabControl Grid.Row="3"
                        Style="{StaticResource ModernTabControlStyle}"
                        SelectedIndex="{Binding SelectedSectionIndex, Mode=TwoWay}">
                <TabItem>
                    <Grid>
                        <ListBox ItemsSource="{Binding FavoritesView}"
                                 ItemTemplate="{StaticResource FavoriteItemTemplate}"
                                 ItemContainerStyle="{StaticResource FavoriteTileListBoxItemStyle}"
                                 Style="{StaticResource ModernListBoxStyle}"
                                 ScrollViewer.CanContentScroll="False"
                                 Visibility="{Binding HasFavorites, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                        </ListBox>

                        <Border Style="{StaticResource CardBorderStyle}"
                                Visibility="{Binding IsFavoritesEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="{Binding FavoritesEmptyTitle}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{Binding FavoritesEmptyDescription}"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid>
                        <ListBox ItemsSource="{Binding SecretsView}"
                                 ItemTemplate="{StaticResource SecretItemTemplate}"
                                 ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                                 Style="{StaticResource ModernListBoxStyle}"
                                 Visibility="{Binding HasSecrets, Converter={StaticResource BoolToVisibilityConverter}}"
                                 helper:LoadMoreOnScrollBehavior.Command="{Binding LoadMoreCommand}"
                                 helper:LoadMoreOnScrollBehavior.CommandParameter="Secrets" />

                        <Border Style="{StaticResource CardBorderStyle}"
                                Visibility="{Binding IsSecretsEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="{Binding SecretsEmptyTitle}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{Binding SecretsEmptyDescription}"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid>
                        <ListBox ItemsSource="{Binding FilesView}"
                                 ItemTemplate="{StaticResource FileItemTemplate}"
                                 ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                                 Style="{StaticResource ModernListBoxStyle}"
                                 Visibility="{Binding HasFiles, Converter={StaticResource BoolToVisibilityConverter}}"
                                 helper:LoadMoreOnScrollBehavior.Command="{Binding LoadMoreCommand}"
                                 helper:LoadMoreOnScrollBehavior.CommandParameter="Files" />

                        <Border Style="{StaticResource CardBorderStyle}"
                                Visibility="{Binding IsFilesEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="{Binding FilesEmptyTitle}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{Binding FilesEmptyDescription}"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid>
                        <ListBox ItemsSource="{Binding TextsView}"
                                 ItemTemplate="{StaticResource TextItemTemplate}"
                                 ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                                 Style="{StaticResource ModernListBoxStyle}"
                                 Visibility="{Binding HasTexts, Converter={StaticResource BoolToVisibilityConverter}}"
                                 helper:LoadMoreOnScrollBehavior.Command="{Binding LoadMoreCommand}"
                                 helper:LoadMoreOnScrollBehavior.CommandParameter="Texts" />

                        <Border Style="{StaticResource CardBorderStyle}"
                                Visibility="{Binding IsTextsEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="{Binding TextsEmptyTitle}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{Binding TextsEmptyDescription}"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid>
                        <ListBox ItemsSource="{Binding UrlsView}"
                                 ItemTemplate="{StaticResource UrlItemTemplate}"
                                 ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                                 Style="{StaticResource ModernListBoxStyle}"
                                 Visibility="{Binding HasUrls, Converter={StaticResource BoolToVisibilityConverter}}"
                                 helper:LoadMoreOnScrollBehavior.Command="{Binding LoadMoreCommand}"
                                 helper:LoadMoreOnScrollBehavior.CommandParameter="Urls" />

                        <Border Style="{StaticResource CardBorderStyle}"
                                Visibility="{Binding IsUrlsEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="{Binding UrlsEmptyTitle}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{Binding UrlsEmptyDescription}"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid>
                        <ListBox ItemsSource="{Binding ImagesView}"
                                 ItemTemplate="{StaticResource ImageItemTemplate}"
                                 ItemContainerStyle="{StaticResource TileListBoxItemStyle}"
                                 Style="{StaticResource ModernListBoxStyle}"
                                 ScrollViewer.CanContentScroll="False"
                                 Visibility="{Binding HasImages, Converter={StaticResource BoolToVisibilityConverter}}"
                                 helper:LoadMoreOnScrollBehavior.Command="{Binding LoadMoreCommand}"
                                 helper:LoadMoreOnScrollBehavior.CommandParameter="Images">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                        </ListBox>

                        <Border Style="{StaticResource CardBorderStyle}"
                                Visibility="{Binding IsImagesEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="{Binding ImagesEmptyTitle}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{Binding ImagesEmptyDescription}"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <views:ImagePreviewOverlay Grid.RowSpan="4"
                                       Panel.ZIndex="50" />
        </Grid>
    </mah:MetroWindow.Content>
</mah:MetroWindow>
