                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="UrlItemTemplate">
            <Border Style="{StaticResource ListCardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="58"
                            Height="58"
                            Background="{StaticResource TealSoftBrush}"
                            CornerRadius="8"
                            VerticalAlignment="Top"
                            ClipToBounds="True">
                        <Image Source="{Binding ImageUrl}"
                               Stretch="UniformToFill" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="2,0,18,0">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Url}"
                                   Margin="0,4,0,0"
                                   Style="{StaticResource MutedTextStyle}"
                                   Foreground="{StaticResource TealBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Description}"
                                   Margin="0,8,0,0"
                                   MaxHeight="42"
                                   Style="{StaticResource MutedTextStyle}"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <Border Grid.Column="2"
                            Style="{StaticResource ActionGroupStyle}"
                            VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource PinIconButtonStyle}">
                                <Button.ToolTip>
                                    <MultiBinding Converter="{StaticResource PinToolTipConverter}">
                                        <Binding Path="IsPinned" />
                                        <Binding Path="DataContext.L.AddToFavoritesToolTip" RelativeSource="{RelativeSource AncestorType={x:Type ListBox}}" />
                                        <Binding Path="DataContext.L.RemoveFromFavoritesToolTip" RelativeSource="{RelativeSource AncestorType={x:Type ListBox}}" />
                                    </MultiBinding>
                                </Button.ToolTip>
                                <Viewbox Width="18" Height="18">
                                    <iconPacks:Material Kind="Star" Width="18" Height="18" />
                                </Viewbox>
                            </Button>
                            <Button Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource IconButtonStyle}"
                                    Margin="2,0,0,0"
                                    ToolTip="{Binding DataContext.L.CopyToolTip, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}">
                                <Viewbox Width="18" Height="18">
                                    <iconPacks:Material Kind="ContentCopy" Width="18" Height="18" />
                                </Viewbox>
                            </Button>
                            <Button Command="{Binding DataContext.OpenLinkCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource IconButtonStyle}"
                                    Margin="2,0,0,0"
                                    ToolTip="{Binding DataContext.L.OpenToolTip, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}">
                                <Viewbox Width="18" Height="18">
                                    <iconPacks:FontAwesome Kind="InternetExplorerBrands" Width="18" Height="18" />
                                </Viewbox>
                            </Button>
                            <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource DangerIconButtonStyle}"
                                    Margin="2,0,0,0"
                                    ToolTip="{Binding DataContext.L.DeleteToolTip, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}">
                                <Viewbox Width="18" Height="18">
                                    <iconPacks:Material Kind="Delete" Width="18" Height="18" />
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ImageItemTemplate">
            <Border Style="{StaticResource ListCardBorderStyle}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="156" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Command="{Binding DataContext.OpenImagePreviewCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource ImagePreviewButtonStyle}"
                            ToolTip="{Binding DataContext.L.OpenToolTip, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}">
                        <Border Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource StrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                ClipToBounds="True">
                            <Image Source="{Binding ImageSource}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   ToolTip="{Binding Name}" />
                        </Border>
                    </Button>

                    <Grid Grid.Row="1" Margin="2,10,2,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding Name}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource MutedTextStyle}"
                                   TextTrimming="CharacterEllipsis" />

                        <Border Grid.Column="1"
                                Style="{StaticResource ActionGroupStyle}">
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource PinIconButtonStyle}">
                                    <Button.ToolTip>
                                        <MultiBinding Converter="{StaticResource PinToolTipConverter}">
                                            <Binding Path="IsPinned" />
                                            <Binding Path="DataContext.L.AddToFavoritesToolTip" RelativeSource="{RelativeSource AncestorType={x:Type ListBox}}" />
                                            <Binding Path="DataContext.L.RemoveFromFavoritesToolTip" RelativeSource="{RelativeSource AncestorType={x:Type ListBox}}" />
                                        </MultiBinding>
                                    </Button.ToolTip>
                                    <Viewbox Width="18" Height="18">
                                        <iconPacks:Material Kind="Star" Width="18" Height="18" />
                                    </Viewbox>
                                </Button>
                                <Button Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource IconButtonStyle}"
                                        Margin="2,0,0,0"
                                        ToolTip="{Binding DataContext.L.CopyToolTip, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}">
                                    <Viewbox Width="18" Height="18">
                                        <iconPacks:Material Kind="ContentCopy" Width="18" Height="18" />
                                    </Viewbox>
                                </Button>
                                <Button Command="{Binding DataContext.OpenImagePreviewCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource IconButtonStyle}"
                                        Margin="2,0,0,0"
                                        ToolTip="{Binding DataContext.L.OpenToolTip, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}">
                                    <Viewbox Width="17" Height="17">
                                        <iconPacks:Material Kind="OpenInNew" Width="17" Height="17" />
                                    </Viewbox>
                                </Button>
                                <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource DangerIconButtonStyle}"
                                        Margin="2,0,0,0"
                                        ToolTip="{Binding DataContext.L.DeleteToolTip, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}">
                                    <Viewbox Width="18" Height="18">
                                        <iconPacks:Material Kind="Delete" Width="18" Height="18" />
                                    </Viewbox>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </mah:MetroWindow.Resources>

    <mah:MetroWindow.Content>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#111827"
                    CornerRadius="8"
                    Padding="22"
                    Effect="{StaticResource SoftShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding L.AppTitle}"
                                   Foreground="White"
                                   FontSize="28"
                                   FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Margin="0,9,0,0">
                            <Ellipse Width="9"
                                     Height="9"
                                     Fill="{StaticResource SuccessBrush}"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="{Binding StatusText}"
                                       Margin="9,0,0,0"
                                       Foreground="#D7DEE8"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="•"
                                       Margin="12,0"
                                       Foreground="#7E8AA0"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding LastActivityText}"
                                       Foreground="#AEB8C8"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Background="#22304A"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14,10"
                                Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="{StaticResource SuccessBrush}"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="{Binding TotalCount}"
                                           Margin="9,0,0,0"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Border Background="#263248"
                                BorderBrush="#46536A"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="4"
                                Margin="0,0,8,0"
                                ToolTip="{Binding L.LanguageToolTip}">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="ENG"
                                             GroupName="InterfaceLanguage"
                                             IsChecked="{Binding IsEnglishLanguageSelected, Mode=OneWay}"
                                             Command="{Binding ChangeLanguageCommand}"
                                             CommandParameter="en"
                                             Style="{StaticResource LanguageToggleButtonStyle}" />
                                <RadioButton Content="РУ"
                                             GroupName="InterfaceLanguage"
                                             IsChecked="{Binding IsRussianLanguageSelected, Mode=OneWay}"
                                             Command="{Binding ChangeLanguageCommand}"
                                             CommandParameter="ru"
                                             Style="{StaticResource LanguageToggleButtonStyle}"
                                             Margin="3,0,0,0" />
                            </StackPanel>
                        </Border>

                        <Button Command="{Binding ImportCommand}"
                                Style="{StaticResource HeaderIconButtonStyle}"
                                Margin="0,0,8,0"
                                ToolTip="{Binding L.ImportToolTip}">
                            <Viewbox Width="19" Height="19">
                                <iconPacks:Material Kind="FileUpload" Width="19" Height="19" />
                            </Viewbox>
                        </Button>

                        <Button Command="{Binding ExportCommand}"
                                Style="{StaticResource HeaderIconButtonStyle}"
                                Margin="0,0,8,0"
                                ToolTip="{Binding L.ExportToolTip}">
                            <Viewbox Width="19" Height="19">
                                <iconPacks:Material Kind="FileDownload" Width="19" Height="19" />
                            </Viewbox>
                        </Button>

                        <Button Command="{Binding ClearCommand}"
                                Style="{StaticResource HeaderDangerIconButtonStyle}"
                                ToolTip="{Binding L.ClearToolTip}">
                            <Viewbox Width="19" Height="19">
                                <iconPacks:Material Kind="DeleteSweep" Width="19" Height="19" />
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,18,0,0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource StrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14,10">
                <Grid MinHeight="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Viewbox Width="17"
                             Height="17"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             Opacity="0.65">
                        <iconPacks:Material Kind="Magnify" Width="17" Height="17" />
                    </Viewbox>

                    <Grid Grid.Column="1"
                          VerticalAlignment="Center">
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{StaticResource TextBrush}"
                                 FontSize="14"
                                 Padding="0"
                                 VerticalContentAlignment="Center" />
                        <TextBlock Text="{Binding L.SearchPlaceholder}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="14"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsSearchPlaceholderVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>

                    <TextBlock Grid.Column="2"
                               Text="{Binding SearchResultText}"
                               Margin="14,0,8,0"
                               VerticalAlignment="Center"
                               Style="{StaticResource MutedTextStyle}"
                               Visibility="{Binding IsSearchActive, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <Button Grid.Column="3"
                            Command="{Binding ClearSearchCommand}"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="{Binding L.ClearSearchToolTip}"
                            Visibility="{Binding IsSearchActive, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Viewbox Width="16" Height="16">
                            <iconPacks:Material Kind="Close" Width="16" Height="16" />
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <WrapPanel Grid.Row="2"
                       Margin="0,14,0,10"
                       ClipToBounds="False">
                <RadioButton Style="{StaticResource SectionTabButtonStyle}"
                             MinWidth="192"
                             IsChecked="{Binding IsFavoritesSectionSelected, Mode=OneWay}"
                             Command="{Binding SelectSectionCommand}"
                             CommandParameter="0">
                    <Grid ClipToBounds="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SectionTabIconStyle}"
                                Background="{StaticResource AmberSoftBrush}">
                            <Grid>
                                <Viewbox Width="15"
                                         Height="15"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <iconPacks:Material Kind="Star" Width="15" Height="15" />
                                </Viewbox>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding L.FavoritesTab}"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Style="{StaticResource TabBadgeStyle}"
                                Background="{StaticResource AmberSoftBrush}">
                            <TextBlock Text="{Binding FavoriteCount, FallbackValue=0}"
                                       Foreground="{StaticResource AmberBrush}"
                                       Style="{StaticResource TabBadgeTextStyle}" />
                        </Border>
                    </Grid>
                </RadioButton>

                <RadioButton Style="{StaticResource SectionTabButtonStyle}"
                             IsChecked="{Binding IsFilesSectionSelected, Mode=OneWay}"
                             Command="{Binding SelectSectionCommand}"
                             CommandParameter="1">
                    <Grid ClipToBounds="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SectionTabIconStyle}"
                                Background="{StaticResource PrimarySoftBrush}">
                            <Grid>
                                <Viewbox Width="15"
                                         Height="15"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <iconPacks:FontAwesome Kind="FileSolid" Width="15" Height="15" />
                                </Viewbox>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding L.FilesTab}"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Style="{StaticResource TabBadgeStyle}"
                                Background="{StaticResource PrimarySoftBrush}">
                            <TextBlock Text="{Binding FileCount, FallbackValue=1}"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Style="{StaticResource TabBadgeTextStyle}" />
                        </Border>
                    </Grid>
                </RadioButton>

                <RadioButton Style="{StaticResource SectionTabButtonStyle}"
                             IsChecked="{Binding IsTextsSectionSelected, Mode=OneWay}"
                             Command="{Binding SelectSectionCommand}"
                             CommandParameter="2">
                    <Grid ClipToBounds="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SectionTabIconStyle}"
                                Background="{StaticResource AmberSoftBrush}">
                            <Grid>
                                <Viewbox Width="15"
                                         Height="15"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <iconPacks:Material Kind="ContentCopy" Width="15" Height="15" />
                                </Viewbox>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding L.TextTab}"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Style="{StaticResource TabBadgeStyle}"
                                Background="{StaticResource AmberSoftBrush}">
                            <TextBlock Text="{Binding TextCount, FallbackValue=3}"
                                       Foreground="{StaticResource AmberBrush}"
                                       Style="{StaticResource TabBadgeTextStyle}" />
                        </Border>
                    </Grid>
                </RadioButton>

                <RadioButton Style="{StaticResource SectionTabButtonStyle}"
                             MinWidth="176"
                             IsChecked="{Binding IsUrlsSectionSelected, Mode=OneWay}"
                             Command="{Binding SelectSectionCommand}"
                             CommandParameter="3">
                    <Grid ClipToBounds="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SectionTabIconStyle}"
                                Background="{StaticResource TealSoftBrush}">
                            <Grid>
                                <Viewbox Width="15"
                                         Height="15"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <iconPacks:FontAwesome Kind="InternetExplorerBrands" Width="15" Height="15" />
                                </Viewbox>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding L.LinksTab}"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Style="{StaticResource TabBadgeStyle}"
                                Background="{StaticResource TealSoftBrush}">
                            <TextBlock Text="{Binding UrlCount, FallbackValue=2}"
                                       Foreground="{StaticResource TealBrush}"
                                       Style="{StaticResource TabBadgeTextStyle}" />
                        </Border>
                    </Grid>
                </RadioButton>

                <RadioButton Style="{StaticResource SectionTabButtonStyle}"
                             MinWidth="224"
                             IsChecked="{Binding IsImagesSectionSelected, Mode=OneWay}"
                             Command="{Binding SelectSectionCommand}"
                             CommandParameter="4">
                    <Grid ClipToBounds="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SectionTabIconStyle}"
                                Background="{StaticResource RoseSoftBrush}">
                            <Grid>
                                <Viewbox Width="15"
                                         Height="15"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <iconPacks:Material Kind="ContentCopy" Width="15" Height="15" />
                                </Viewbox>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding L.ImagesTab}"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Style="{StaticResource TabBadgeStyle}"
                                Background="{StaticResource RoseSoftBrush}">
                            <TextBlock Text="{Binding ImageCount, FallbackValue=2}"
                                       Foreground="{StaticResource RoseBrush}"
                                       Style="{StaticResource TabBadgeTextStyle}" />
                        </Border>
                    </Grid>
                </RadioButton>
            </WrapPanel>

            <TabControl Grid.Row="3"
                        Style="{StaticResource ModernTabControlStyle}"
                        SelectedIndex="{Binding SelectedSectionIndex, Mode=TwoWay}">
                <TabItem>
                    <Grid>
                        <ListBox ItemsSource="{Binding FavoritesView}"
                                 ItemTemplate="{StaticResource FavoriteItemTemplate}"
                                 ItemContainerStyle="{StaticResource FavoriteTileListBoxItemStyle}"
                                 Style="{StaticResource ModernListBoxStyle}"
                                 Visibility="{Binding HasFavorites, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                        </ListBox>

                        <Border Style="{StaticResource CardBorderStyle}"
                                Visibility="{Binding IsFavoritesEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="{Binding FavoritesEmptyTitle}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{Binding FavoritesEmptyDescription}"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid>
                        <ListBox ItemsSource="{Binding FilesView}"
                                 ItemTemplate="{StaticResource FileItemTemplate}"
                                 ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                                 Style="{StaticResource ModernListBoxStyle}"
                                 Visibility="{Binding HasFiles, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <Border Style="{StaticResource CardBorderStyle}"
                                Visibility="{Binding IsFilesEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="{Binding FilesEmptyTitle}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{Binding FilesEmptyDescription}"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid>
                        <ListBox ItemsSource="{Binding TextsView}"
                                 ItemTemplate="{StaticResource TextItemTemplate}"
                                 ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                                 Style="{StaticResource ModernListBoxStyle}"
                                 Visibility="{Binding HasTexts, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <Border Style="{StaticResource CardBorderStyle}"
                                Visibility="{Binding IsTextsEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="{Binding TextsEmptyTitle}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{Binding TextsEmptyDescription}"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid>
                        <ListBox ItemsSource="{Binding UrlsView}"
                                 ItemTemplate="{StaticResource UrlItemTemplate}"
                                 ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                                 Style="{StaticResource ModernListBoxStyle}"
                                 Visibility="{Binding HasUrls, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <Border Style="{StaticResource CardBorderStyle}"
                                Visibility="{Binding IsUrlsEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="{Binding UrlsEmptyTitle}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{Binding UrlsEmptyDescription}"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid>
                        <ListBox ItemsSource="{Binding ImagesView}"
                                 ItemTemplate="{StaticResource ImageItemTemplate}"
                                 ItemContainerStyle="{StaticResource TileListBoxItemStyle}"
                                 Style="{StaticResource ModernListBoxStyle}"
                                 Visibility="{Binding HasImages, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                        </ListBox>

                        <Border Style="{StaticResource CardBorderStyle}"
                                Visibility="{Binding IsImagesEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="{Binding ImagesEmptyTitle}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{Binding ImagesEmptyDescription}"
                                           Margin="0,6,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <Border Grid.RowSpan="4"
                    Panel.ZIndex="50"
                    Background="#B3111827"
                    CornerRadius="8"
                    Padding="28"
                    Visibility="{Binding IsImagePreviewOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Effect="{StaticResource SoftShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="2,0,2,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding PreviewImageName}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding PreviewZoomText}"
                                           Margin="0,4,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Style="{StaticResource ActionGroupStyle}"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding ZoomOutImageCommand}"
                                            Style="{StaticResource IconButtonStyle}"
                                            ToolTip="{Binding L.ZoomOutToolTip}">
                                        <TextBlock Text="-"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Button>
                                    <Button Command="{Binding ResetImageZoomCommand}"
                                            Style="{StaticResource IconButtonStyle}"
                                            Margin="2,0,0,0"
                                            ToolTip="{Binding L.ResetZoomToolTip}">
                                        <Viewbox Width="17" Height="17">
                                            <iconPacks:Material Kind="Magnify" Width="17" Height="17" />
                                        </Viewbox>
                                    </Button>
                                    <Button Command="{Binding ZoomInImageCommand}"
                                            Style="{StaticResource IconButtonStyle}"
                                            Margin="2,0,0,0"
                                            ToolTip="{Binding L.ZoomInToolTip}">
                                        <TextBlock Text="+"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Button>
                                    <Button Command="{Binding CopyCommand}"
                                            CommandParameter="{Binding PreviewImage}"
                                            Style="{StaticResource IconButtonStyle}"
                                            Margin="2,0,0,0"
                                            ToolTip="{Binding L.CopyToolTip}">
                                        <Viewbox Width="18" Height="18">
                                            <iconPacks:Material Kind="ContentCopy" Width="18" Height="18" />
                                        </Viewbox>
                                    </Button>
                                    <Button Command="{Binding CloseImagePreviewCommand}"
                                            Style="{StaticResource DangerIconButtonStyle}"
                                            Margin="2,0,0,0"
                                            ToolTip="{Binding L.CloseToolTip}">
                                        <Viewbox Width="18" Height="18">
                                            <iconPacks:Material Kind="Close" Width="18" Height="18" />
                                        </Viewbox>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="1"
                                Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource StrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                ClipToBounds="True">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          PanningMode="Both"
                                          helper:ScrollViewerPanBehavior.IsEnabled="True"
                                          helper:MouseWheelCommandBehavior.WheelUpCommand="{Binding ZoomInImageCommand}"
                                          helper:MouseWheelCommandBehavior.WheelDownCommand="{Binding ZoomOutImageCommand}">
                                <Grid MinHeight="420"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                                    <Image Source="{Binding PreviewImageSource}"
                                           Stretch="None"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.LayoutTransform>
                                            <ScaleTransform ScaleX="{Binding PreviewZoom}"
                                                            ScaleY="{Binding PreviewZoom}" />
                                        </Image.LayoutTransform>
                                    </Image>
                                </Grid>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </mah:MetroWindow.Content>
</mah:MetroWindow>
