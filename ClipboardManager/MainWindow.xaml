<mah:MetroWindow x:Class="ClipboardManager.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 mc:Ignorable="d"
                 Title="Clipboard Manager"
                 Width="1120"
                 Height="760"
                 MinWidth="760"
                 MinHeight="560"
                 TitleBarHeight="44"
                 TitleCharacterCasing="Normal"
                 TitleForeground="#F8FAFC"
                 WindowTitleBrush="#111827"
                 NonActiveWindowTitleBrush="#1F2937"
                 GlowBrush="#2563EB"
                 BorderBrush="#111827"
                 BorderThickness="1"
                 ShowIconOnTitleBar="False"
                 WindowStartupLocation="CenterScreen"
                 Background="#F6F7F9"
                 FontFamily="Segoe UI"
                 Loaded="MetroWindow_Loaded"
                 Closing="MetroWindow_Closing"
                 TextOptions.TextFormattingMode="Display"
                 UseLayoutRounding="True">
    <mah:MetroWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F6F7F9" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F0F4F8" />
        <SolidColorBrush x:Key="StrokeBrush" Color="#DDE5EF" />
        <SolidColorBrush x:Key="TextBrush" Color="#182033" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#687386" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="PrimarySoftBrush" Color="#EAF1FF" />
        <SolidColorBrush x:Key="TealBrush" Color="#0F766E" />
        <SolidColorBrush x:Key="TealSoftBrush" Color="#E6F5F3" />
        <SolidColorBrush x:Key="AmberBrush" Color="#B7791F" />
        <SolidColorBrush x:Key="AmberSoftBrush" Color="#FFF7E6" />
        <SolidColorBrush x:Key="RoseBrush" Color="#BE3455" />
        <SolidColorBrush x:Key="RoseSoftBrush" Color="#FFF0F3" />
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626" />
        <SolidColorBrush x:Key="DangerSoftBrush" Color="#FEF2F2" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#10B981" />

        <DropShadowEffect x:Key="SoftShadow"
                          BlurRadius="22"
                          ShadowDepth="0"
                          Opacity="0.08"
                          Color="#111827" />

        <Style x:Key="MutedTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="LineHeight" Value="18" />
        </Style>

        <Style x:Key="TabBadgeStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ClipToBounds" Value="False" />
        </Style>

        <Style x:Key="TabBadgeTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="LineHeight" Value="14" />
        </Style>

        <Style x:Key="SectionTabIconStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#344256" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PrimarySoftBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#CBDDFE" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#B94B5F" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFF5F7" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#F4C9D1" />
                                <Setter Property="Foreground" Value="#A93147" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderDangerIconButtonStyle"
               TargetType="{x:Type Button}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#E5A1AE" />
            <Setter Property="Background" Value="#263248" />
            <Setter Property="BorderBrush" Value="#46536A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#35283A" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#7A4252" />
                                <Setter Property="Foreground" Value="#F3B4C0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionGroupStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Effect" Value="{StaticResource SoftShadow}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="StatCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Width" Value="255" />
            <Setter Property="Height" Value="80" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Effect" Value="{x:Null}" />
        </Style>

        <Style x:Key="ModernListBoxStyle" TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>

        <Style x:Key="CardListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TileListBoxItemStyle"
               TargetType="{x:Type ListBoxItem}"
               BasedOn="{StaticResource CardListBoxItemStyle}">
            <Setter Property="Width" Value="272" />
            <Setter Property="Margin" Value="0,0,12,12" />
        </Style>

        <Style x:Key="ModernTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <ContentPresenter ContentSource="SelectedContent"
                                          KeyboardNavigation.TabIndex="1" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTabButtonStyle" TargetType="{x:Type RadioButton}">
            <Setter Property="MinWidth" Value="168" />
            <Setter Property="Height" Value="50" />
            <Setter Property="Margin" Value="0,0,10,14" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PrimarySoftBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="10,9" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabRoot"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource StrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                ClipToBounds="False"
                                SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              ClipToBounds="False"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabRoot" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabRoot" Property="Background" Value="{StaticResource PrimarySoftBrush}" />
                                <Setter TargetName="TabRoot" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="FileItemTemplate">
            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="44"
                            Height="44"
                            Background="{StaticResource PrimarySoftBrush}"
                            CornerRadius="8">
                        <Grid>
                            <Viewbox Width="19"
                                     Height="19"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <iconPacks:FontAwesome Kind="FileSolid" Width="19" Height="19" />
                            </Viewbox>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="14,0,18,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding FilePath}"
                                   Margin="0,5,0,0"
                                   Style="{StaticResource MutedTextStyle}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <Border Grid.Column="2"
                            Style="{StaticResource ActionGroupStyle}"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Копировать">
                                <Viewbox Width="18" Height="18">
                                    <iconPacks:Material Kind="ContentCopy" Width="18" Height="18" />
                                </Viewbox>
                            </Button>
                            <Button Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource IconButtonStyle}"
                                    Margin="2,0,0,0"
                                    ToolTip="Открыть">
                                <Viewbox Width="17" Height="17">
                                    <iconPacks:FontAwesome Kind="FileSolid" Width="17" Height="17" />
                                </Viewbox>
                            </Button>
                            <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource DangerIconButtonStyle}"
                                    Margin="2,0,0,0"
                                    ToolTip="Удалить">
                                <Viewbox Width="18" Height="18">
                                    <iconPacks:Material Kind="Delete" Width="18" Height="18" />
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TextItemTemplate">
            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding Text}"
                               MaxHeight="150"
                               FontSize="14"
                               LineHeight="21"
                               Foreground="{StaticResource TextBrush}"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis" />

                    <Border Grid.Column="1"
                            Style="{StaticResource ActionGroupStyle}"
                            Margin="18,0,0,0"
                            VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Копировать">
                                <Viewbox Width="18" Height="18">
                                    <iconPacks:Material Kind="ContentCopy" Width="18" Height="18" />
                                </Viewbox>
                            </Button>
                            <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource DangerIconButtonStyle}"
                                    Margin="2,0,0,0"
                                    ToolTip="Удалить">
                                <Viewbox Width="18" Height="18">
                                    <iconPacks:Material Kind="Delete" Width="18" Height="18" />
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="UrlItemTemplate">
            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="58"
                            Height="58"
                            Background="{StaticResource TealSoftBrush}"
                            CornerRadius="8"
                            VerticalAlignment="Top"
                            ClipToBounds="True">
                        <Image Source="{Binding ImageUrl}"
                               Stretch="UniformToFill" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="2,0,18,0">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Url}"
                                   Margin="0,4,0,0"
                                   Style="{StaticResource MutedTextStyle}"
                                   Foreground="{StaticResource TealBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Description}"
                                   Margin="0,8,0,0"
                                   MaxHeight="42"
                                   Style="{StaticResource MutedTextStyle}"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <Border Grid.Column="2"
                            Style="{StaticResource ActionGroupStyle}"
                            VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Копировать">
                                <Viewbox Width="18" Height="18">
                                    <iconPacks:Material Kind="ContentCopy" Width="18" Height="18" />
                                </Viewbox>
                            </Button>
                            <Button Command="{Binding DataContext.OpenLinkCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource IconButtonStyle}"
                                    Margin="2,0,0,0"
                                    ToolTip="Открыть">
                                <Viewbox Width="18" Height="18">
                                    <iconPacks:FontAwesome Kind="InternetExplorerBrands" Width="18" Height="18" />
                                </Viewbox>
                            </Button>
                            <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource DangerIconButtonStyle}"
                                    Margin="2,0,0,0"
                                    ToolTip="Удалить">
                                <Viewbox Width="18" Height="18">
                                    <iconPacks:Material Kind="Delete" Width="18" Height="18" />
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ImageItemTemplate">
            <Border Style="{StaticResource CardBorderStyle}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="156" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            ClipToBounds="True">
                        <Image Source="{Binding ImageSource}"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               ToolTip="{Binding Name}" />
                    </Border>

                    <Grid Grid.Row="1" Margin="2,10,2,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding Name}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource MutedTextStyle}"
                                   TextTrimming="CharacterEllipsis" />

                        <Border Grid.Column="1"
                                Style="{StaticResource ActionGroupStyle}">
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource IconButtonStyle}"
                                        ToolTip="Копировать">
                                    <Viewbox Width="18" Height="18">
                                        <iconPacks:Material Kind="ContentCopy" Width="18" Height="18" />
                                    </Viewbox>
                                </Button>
                                <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource DangerIconButtonStyle}"
                                        Margin="2,0,0,0"
                                        ToolTip="Удалить">
                                    <Viewbox Width="18" Height="18">
                                        <iconPacks:Material Kind="Delete" Width="18" Height="18" />
                                    </Viewbox>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </mah:MetroWindow.Resources>

    <mah:MetroWindow.Content>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#111827"
                    CornerRadius="8"
                    Padding="22"
                    Effect="{StaticResource SoftShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Буфер обмена"
                                   Foreground="White"
                                   FontSize="28"
                                   FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Margin="0,9,0,0">
                            <Ellipse Width="9"
                                     Height="9"
                                     Fill="{StaticResource SuccessBrush}"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="{Binding StatusText}"
                                       Margin="9,0,0,0"
                                       Foreground="#D7DEE8"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="•"
                                       Margin="12,0"
                                       Foreground="#7E8AA0"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding LastActivityText}"
                                       Foreground="#AEB8C8"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Background="#22304A"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14,10"
                                Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="{StaticResource SuccessBrush}"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="{Binding TotalCount}"
                                           Margin="9,0,0,0"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Button Command="{Binding ClearCommand}"
                                Style="{StaticResource HeaderDangerIconButtonStyle}"
                                ToolTip="Очистить">
                            <Viewbox Width="19" Height="19">
                                <iconPacks:Material Kind="DeleteSweep" Width="19" Height="19" />
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <WrapPanel Grid.Row="1"
                       Margin="0,18,0,10"
                       ClipToBounds="False">
                <RadioButton Style="{StaticResource SectionTabButtonStyle}"
                             IsChecked="{Binding IsFilesSectionSelected, Mode=OneWay}"
                             Command="{Binding SelectSectionCommand}"
                             CommandParameter="0">
                    <Grid ClipToBounds="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SectionTabIconStyle}"
                                Background="{StaticResource PrimarySoftBrush}">
                            <Grid>
                                <Viewbox Width="15"
                                         Height="15"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <iconPacks:FontAwesome Kind="FileSolid" Width="15" Height="15" />
                                </Viewbox>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="Файлы"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Style="{StaticResource TabBadgeStyle}"
                                Background="{StaticResource PrimarySoftBrush}">
                            <TextBlock Text="{Binding FileCount, FallbackValue=1}"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Style="{StaticResource TabBadgeTextStyle}" />
                        </Border>
                    </Grid>
                </RadioButton>

                <RadioButton Style="{StaticResource SectionTabButtonStyle}"
                             IsChecked="{Binding IsTextsSectionSelected, Mode=OneWay}"
                             Command="{Binding SelectSectionCommand}"
                             CommandParameter="1">
                    <Grid ClipToBounds="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SectionTabIconStyle}"
                                Background="{StaticResource AmberSoftBrush}">
                            <Grid>
                                <Viewbox Width="15"
                                         Height="15"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <iconPacks:Material Kind="ContentCopy" Width="15" Height="15" />
                                </Viewbox>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="Текст"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Style="{StaticResource TabBadgeStyle}"
                                Background="{StaticResource AmberSoftBrush}">
                            <TextBlock Text="{Binding TextCount, FallbackValue=3}"
                                       Foreground="{StaticResource AmberBrush}"
                                       Style="{StaticResource TabBadgeTextStyle}" />
                        </Border>
                    </Grid>
                </RadioButton>

                <RadioButton Style="{StaticResource SectionTabButtonStyle}"
                             MinWidth="176"
                             IsChecked="{Binding IsUrlsSectionSelected, Mode=OneWay}"
                             Command="{Binding SelectSectionCommand}"
                             CommandParameter="2">
                    <Grid ClipToBounds="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SectionTabIconStyle}"
                                Background="{StaticResource TealSoftBrush}">
                            <Grid>
                                <Viewbox Width="15"
                                         Height="15"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <iconPacks:FontAwesome Kind="InternetExplorerBrands" Width="15" Height="15" />
                                </Viewbox>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="Ссылки"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Style="{StaticResource TabBadgeStyle}"
                                Background="{StaticResource TealSoftBrush}">
                            <TextBlock Text="{Binding UrlCount, FallbackValue=2}"
                                       Foreground="{StaticResource TealBrush}"
                                       Style="{StaticResource TabBadgeTextStyle}" />
                        </Border>
                    </Grid>
                </RadioButton>

                <RadioButton Style="{StaticResource SectionTabButtonStyle}"
                             MinWidth="224"
                             IsChecked="{Binding IsImagesSectionSelected, Mode=OneWay}"
                             Command="{Binding SelectSectionCommand}"
                             CommandParameter="3">
                    <Grid ClipToBounds="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource SectionTabIconStyle}"
                                Background="{StaticResource RoseSoftBrush}">
                            <Grid>
                                <Viewbox Width="15"
                                         Height="15"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <iconPacks:Material Kind="ContentCopy" Width="15" Height="15" />
                                </Viewbox>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="Изображения"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="2"
                                Style="{StaticResource TabBadgeStyle}"
                                Background="{StaticResource RoseSoftBrush}">
                            <TextBlock Text="{Binding ImageCount, FallbackValue=2}"
                                       Foreground="{StaticResource RoseBrush}"
                                       Style="{StaticResource TabBadgeTextStyle}" />
                        </Border>
                    </Grid>
                </RadioButton>
            </WrapPanel>

            <TabControl Grid.Row="2"
                        Style="{StaticResource ModernTabControlStyle}"
                        SelectedIndex="{Binding SelectedSectionIndex, Mode=TwoWay}">
                <TabItem>
                    <Grid>
                        <ListBox ItemsSource="{Binding Files}"
                                 ItemTemplate="{StaticResource FileItemTemplate}"
                                 ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                                 Style="{StaticResource ModernListBoxStyle}"
                                 Visibility="{Binding HasFiles, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <Border Style="{StaticResource CardBorderStyle}"
                                Visibility="{Binding IsFilesEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="Файлов пока нет"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="Скопируйте файл в системе, и он появится здесь."
                                           Margin="0,6,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid>
                        <ListBox ItemsSource="{Binding Texts}"
                                 ItemTemplate="{StaticResource TextItemTemplate}"
                                 ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                                 Style="{StaticResource ModernListBoxStyle}"
                                 Visibility="{Binding HasTexts, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <Border Style="{StaticResource CardBorderStyle}"
                                Visibility="{Binding IsTextsEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="Текстовых записей пока нет"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="Скопируйте любой текст, чтобы добавить его в историю."
                                           Margin="0,6,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid>
                        <ListBox ItemsSource="{Binding Urls}"
                                 ItemTemplate="{StaticResource UrlItemTemplate}"
                                 ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                                 Style="{StaticResource ModernListBoxStyle}"
                                 Visibility="{Binding HasUrls, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <Border Style="{StaticResource CardBorderStyle}"
                                Visibility="{Binding IsUrlsEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="Ссылок пока нет"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="Скопируйте URL, чтобы увидеть карточку ссылки."
                                           Margin="0,6,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem>
                    <Grid>
                        <ListBox ItemsSource="{Binding Images}"
                                 ItemTemplate="{StaticResource ImageItemTemplate}"
                                 ItemContainerStyle="{StaticResource TileListBoxItemStyle}"
                                 Style="{StaticResource ModernListBoxStyle}"
                                 Visibility="{Binding HasImages, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                        </ListBox>

                        <Border Style="{StaticResource CardBorderStyle}"
                                Visibility="{Binding IsImagesEmpty, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="Изображений пока нет"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="Скопируйте картинку, чтобы добавить ее в галерею."
                                           Margin="0,6,0,0"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </mah:MetroWindow.Content>
</mah:MetroWindow>
