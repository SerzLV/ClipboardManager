<UserControl x:Class="ClipboardManager.Views.SettingsFlyoutContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="22,18,22,26">
            <TextBlock Text="{Binding L.SettingsShellTitle}"
                       Foreground="{DynamicResource TextBrush}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10" />

            <Border Style="{DynamicResource SettingsRowStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="30"
                            Height="30"
                            CornerRadius="8"
                            Background="{DynamicResource PrimarySoftBrush}"
                            VerticalAlignment="Center">
                        <Viewbox Width="16" Height="16">
                            <iconPacks:Material Kind="OpenInNew" Width="16" Height="16" />
                        </Viewbox>
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="2,0,14,0">
                        <TextBlock Text="{Binding L.MinimizeToTraySetting}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                    </StackPanel>

                    <CheckBox Grid.Column="2"
                              IsChecked="{Binding MinimizeToTray, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{DynamicResource SettingsSwitchStyle}" />
                </Grid>
            </Border>

            <Border Style="{DynamicResource SettingsRowStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="30"
                            Height="30"
                            CornerRadius="8"
                            Background="{DynamicResource DangerSoftBrush}"
                            VerticalAlignment="Center">
                        <Viewbox Width="16" Height="16">
                            <iconPacks:Material Kind="DeleteSweep" Width="16" Height="16" />
                        </Viewbox>
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="2,0,14,0">
                        <TextBlock Text="{Binding L.ClearHistorySetting}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding L.ClearHistoryDescription}"
                                   Margin="0,4,0,0"
                                   Style="{DynamicResource MutedTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Button Grid.Column="2"
                            MinWidth="96"
                            Padding="14,8"
                            Background="{DynamicResource DangerSoftBrush}"
                            BorderBrush="#FECACA"
                            BorderThickness="1"
                            Command="{Binding ClearCommand}"
                            Content="{Binding L.ClearHistoryButton}"
                            Foreground="{DynamicResource DangerBrush}"
                            FontSize="12"
                            FontWeight="SemiBold"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Style="{DynamicResource SettingsRowStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="30"
                            Height="30"
                            CornerRadius="8"
                            Background="{DynamicResource AmberSoftBrush}"
                            VerticalAlignment="Center">
                        <Viewbox Width="16" Height="16">
                            <iconPacks:Material Kind="Star" Width="16" Height="16" />
                        </Viewbox>
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="2,0,14,0">
                        <TextBlock Text="{Binding L.StartWithWindowsSetting}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                    </StackPanel>

                    <CheckBox Grid.Column="2"
                              IsChecked="{Binding StartWithWindows, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{DynamicResource SettingsSwitchStyle}" />
                </Grid>
            </Border>

            <TextBlock Text="{Binding L.SettingsHistoryTitle}"
                       Foreground="{DynamicResource TextBrush}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Margin="0,10,0,10" />

            <Border Style="{DynamicResource SettingsRowStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="30"
                            Height="30"
                            CornerRadius="8"
                            Background="{DynamicResource PrimarySoftBrush}"
                            VerticalAlignment="Center">
                        <Viewbox Width="16" Height="16">
                            <iconPacks:Material Kind="History" Width="16" Height="16" />
                        </Viewbox>
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="2,0,14,0">
                        <TextBlock Text="{Binding L.HistoryBatchSizeSetting}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding L.HistoryBatchSizeDescription}"
                                   Margin="0,4,0,0"
                                   Style="{DynamicResource MutedTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <ComboBox Grid.Column="2"
                              Width="96"
                              ItemsSource="{Binding HistoryBatchSizeOptions}"
                              SelectedItem="{Binding HistoryBatchSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{DynamicResource SettingsComboBoxStyle}"
                              VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Style="{DynamicResource SettingsRowStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="30"
                            Height="30"
                            CornerRadius="8"
                            Background="{DynamicResource TealSoftBrush}"
                            VerticalAlignment="Center">
                        <Viewbox Width="16" Height="16">
                            <iconPacks:FontAwesome Kind="InternetExplorerBrands" Width="16" Height="16" />
                        </Viewbox>
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="2,0,14,0">
                        <TextBlock Text="{Binding L.LinkRefreshIntervalSetting}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding L.LinkRefreshIntervalDescription}"
                                   Margin="0,4,0,0"
                                   Style="{DynamicResource MutedTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <ComboBox Grid.Column="2"
                              Width="154"
                              ItemsSource="{Binding LinkRefreshIntervalOptions}"
                              SelectedValue="{Binding LinkRefreshIntervalDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Days"
                              Style="{DynamicResource SettingsComboBoxStyle}"
                              VerticalAlignment="Center">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
            </Border>

            <Border Style="{DynamicResource SettingsRowStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="30"
                            Height="30"
                            CornerRadius="8"
                            Background="{DynamicResource DangerSoftBrush}"
                            VerticalAlignment="Center">
                        <Viewbox Width="16" Height="16">
                            <iconPacks:Material Kind="DeleteSweep" Width="16" Height="16" />
                        </Viewbox>
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="2,0,14,0">
                        <TextBlock Text="{Binding L.ClearLinkPreviewCacheSetting}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding L.ClearLinkPreviewCacheDescription}"
                                   Margin="0,4,0,0"
                                   Style="{DynamicResource MutedTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Button Grid.Column="2"
                            MinWidth="96"
                            Padding="14,8"
                            Background="#F8FAFC"
                            BorderBrush="{DynamicResource StrokeBrush}"
                            BorderThickness="1"
                            Command="{Binding ClearLinkPreviewCacheCommand}"
                            Content="{Binding L.ClearLinkPreviewCacheButton}"
                            Foreground="{DynamicResource TextBrush}"
                            FontSize="12"
                            FontWeight="SemiBold"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

            <TextBlock Text="{Binding L.SettingsShortcutsTitle}"
                       Foreground="{DynamicResource TextBrush}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Margin="0,10,0,10" />

            <Border Style="{DynamicResource SettingsRowStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="38" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="30"
                            Height="30"
                            CornerRadius="8"
                            Background="{DynamicResource TealSoftBrush}"
                            VerticalAlignment="Center">
                        <Viewbox Width="16" Height="16">
                            <iconPacks:Material Kind="ContentCopy" Width="16" Height="16" />
                        </Viewbox>
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="2,0,14,0">
                        <TextBlock Text="{Binding L.GlobalHotKeySetting}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                        <Border Background="#F8FAFC"
                                BorderBrush="{DynamicResource StrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"
                                Padding="8,4">
                            <TextBlock Text="{Binding GlobalHotKeyText}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>

                    <CheckBox Grid.Column="2"
                              IsChecked="{Binding GlobalHotKeyEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{DynamicResource SettingsSwitchStyle}" />
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
