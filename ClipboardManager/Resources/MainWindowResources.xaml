                                    Style="{StaticResource DangerIconButtonStyle}"
                                    Margin="2,0,0,0"
                                    ToolTip="{Binding DataContext.L.DeleteToolTip, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}">
                                <Viewbox Width="18" Height="18">
                                    <iconPacks:Material Kind="Delete" Width="18" Height="18" />
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ImageItemTemplate">
            <Border Style="{StaticResource ListCardBorderStyle}"
                    Padding="10"
                    Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="136" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Command="{Binding DataContext.OpenImagePreviewCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource ImagePreviewButtonStyle}"
                            ToolTip="{Binding DataContext.L.OpenToolTip, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}">
                        <Border Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource StrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                ClipToBounds="True">
                            <Image Source="{Binding ThumbnailSource}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   ToolTip="{Binding Name}" />
                        </Border>
                    </Button>

                    <Grid Grid.Row="1" Margin="2,8,2,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20" />
                            <RowDefinition Height="36" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding Name}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource MutedTextStyle}"
                                   TextTrimming="CharacterEllipsis" />

                        <Border Grid.Row="1"
                                Style="{StaticResource CompactActionGroupStyle}"
                                HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource CompactPinIconButtonStyle}">
                                    <Button.ToolTip>
                                        <MultiBinding Converter="{StaticResource PinToolTipConverter}">
                                            <Binding Path="IsPinned" />
                                            <Binding Path="DataContext.L.AddToFavoritesToolTip" RelativeSource="{RelativeSource AncestorType={x:Type ListBox}}" />
                                            <Binding Path="DataContext.L.RemoveFromFavoritesToolTip" RelativeSource="{RelativeSource AncestorType={x:Type ListBox}}" />
                                        </MultiBinding>
                                    </Button.ToolTip>
                                    <Viewbox Width="16" Height="16">
                                        <iconPacks:Material Kind="Star" Width="16" Height="16" />
                                    </Viewbox>
                                </Button>
                                <Button Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource CompactIconButtonStyle}"
                                        Margin="2,0,0,0"
                                        ToolTip="{Binding DataContext.L.CopyToolTip, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}">
                                    <Viewbox Width="16" Height="16">
                                        <iconPacks:Material Kind="ContentCopy" Width="16" Height="16" />
                                    </Viewbox>
                                </Button>
                                <Button Command="{Binding DataContext.SaveImageCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource CompactIconButtonStyle}"
                                        Margin="2,0,0,0"
                                        ToolTip="{Binding DataContext.L.SaveImageToolTip, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}">
                                    <Viewbox Width="16" Height="16">
                                        <iconPacks:Material Kind="ContentSave" Width="16" Height="16" />
                                    </Viewbox>
                                </Button>
                                <Button Command="{Binding DataContext.OpenImagePreviewCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource CompactIconButtonStyle}"
                                        Margin="2,0,0,0"
                                        ToolTip="{Binding DataContext.L.OpenToolTip, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}">
                                    <Viewbox Width="16" Height="16">
                                        <iconPacks:Material Kind="OpenInNew" Width="16" Height="16" />
                                    </Viewbox>
                                </Button>
                                <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource CompactDangerIconButtonStyle}"
                                        Margin="2,0,0,0"
                                        ToolTip="{Binding DataContext.L.DeleteToolTip, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}">
                                    <Viewbox Width="16" Height="16">
                                        <iconPacks:Material Kind="Delete" Width="16" Height="16" />
                                    </Viewbox>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
</ResourceDictionary>
